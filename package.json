{
    "name": "obsidian-term",
    "version": "1.1.0",
    "description": "Obsidian Terminal Plugin with @ autocomplete",
    "main": "main.js",
    "scripts": {
        "build:helper": "node scripts/build-helper.mjs",
        "dev": "node esbuild.config.mjs",
        "build": "npm run build:helper && node esbuild.config.mjs production",
        "deploy": "node scripts/deploy.mjs",
        "release:github": "node scripts/release-github.mjs"
    },
    "keywords": [
        "obsidian",
        "terminal",
        "xterm"
    ],
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.10.0",
        "builtin-modules": "^3.3.0",
        "esbuild": "^0.19.0",
        "obsidian": "latest",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0"
    }
}
